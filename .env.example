# Copy to .env and fill in real values. Never commit .env.

# --- Sanity (Tripideas content source) ---
SANITY_PROJECT_ID=n1o990un
SANITY_DATASET=production
SANITY_API_VERSION=v2025-02-19
SANITY_TOKEN=

# Optional: defaults to "published" if unset. "raw" includes drafts.
SANITY_DEFAULT_PERSPECTIVE=published

# --- Anthropic (chat orchestrator) ---
# Get a key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Optional: pin a specific model. Defaults to claude-sonnet-4-6.
# Other choices: claude-haiku-4-5, claude-opus-4-7
ANTHROPIC_MODEL=claude-sonnet-4-6
