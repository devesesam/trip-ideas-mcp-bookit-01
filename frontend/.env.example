# Copy to .env.local for local development overrides.
# Vite exposes any var prefixed with VITE_ to the frontend bundle.

# Where the chat widget POSTs messages. Defaults to http://localhost:8000/chat
# (your local uvicorn-running backend). Set to your deployed Modal URL for
# Netlify previews / production builds.
VITE_API_URL=http://localhost:8000/chat
